{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run-seeder",
      "type": "shell",
      "command": "flutter",
      "args": [
        "run",
        "-d",
        "windows",
        "--dart-define=SNACK_BURGER_RUN_SEEDER=true"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "SNACK_BURGER_RUN_SEEDER": "true"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
